DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=example.com,www.example.com,backend
DJANGO_USE_X_FORWARDED_HOST=1

DJANGO_BEHIND_HTTPS_PROXY=1
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=1

CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

POSTGRES_DB=resident
POSTGRES_USER=resident
POSTGRES_PASSWORD=

FRONTEND_PUBLISH=80

GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# --- SMTP (Timeweb по умолчанию) ---
EMAIL_HOST=smtp.timeweb.ru
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USE_TLS=0
EMAIL_HOST_USER=leads@residentservicerf.ru
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Миграционный сервис «Резидент» <leads@residentservicerf.ru>
LEADS_RECIPIENT_EMAILS=info@residentservicerf.ru
LEADS_EMAIL_SUBJECT_PREFIX=[Резидент]
LEADS_EMAIL_FAIL_SILENTLY=1
SITE_PUBLIC_URL=https://residentservicerf.ru
